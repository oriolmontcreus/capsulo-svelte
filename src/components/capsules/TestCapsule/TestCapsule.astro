---
import type { TestCapsuleData } from "./test-capsule.types";

interface Props extends Partial<TestCapsuleData> {}

const {
	eyebrow = "Capsulo prototype",
	title = "Autodetected capsule",
	description = "This content is editable from the prototype admin.",
	ctaLabel = "Read more"
} = Astro.props;
---

<section class="rounded-xl border border-zinc-200 bg-white p-6 shadow-xs dark:border-zinc-800 dark:bg-zinc-900">
	<p class="text-xs font-semibold tracking-wide text-blue-600 uppercase dark:text-blue-400">
		{eyebrow}
	</p>
	<h2 class="mt-2 text-2xl font-semibold text-zinc-900 dark:text-zinc-100">{title}</h2>
	<p class="mt-3 text-sm text-zinc-600 dark:text-zinc-300">{description}</p>
	<button
		type="button"
		class="mt-4 inline-flex h-9 items-center rounded-md bg-zinc-900 px-4 text-sm font-medium text-white dark:bg-zinc-100 dark:text-zinc-900"
	>
		{ctaLabel}
	</button>
</section>
