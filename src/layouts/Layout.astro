---
import "../styles/global.css";
import ModeWatcherClient from "$lib/components/ModeWatcherClient.svelte";
import { ClientRouter } from "astro:transitions";
---

<!doctype html>
<html lang="en" transition:animate="none">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<ClientRouter fallback="swap" />
	</head>
	<body>
		<slot />
		<ModeWatcherClient client:load />
		<script>
			import {
				initPagePreviewBridge,
				teardownPagePreviewBridge
			} from "$lib/PageEditor/page-preview-bridge";
			import { PAGE_EDITOR_PREVIEW_PARAM } from "$lib/PageEditor/preview-channel";

			function pathnameToPageId(pathname: string) {
				const clean = pathname.replace(/\/+$/, "");
				if (!clean || clean === "/") return "index";
				return clean
					.split("/")
					.filter(Boolean)
					.map((segment: string) => decodeURIComponent(segment))
					.join("/");
			}

			async function bootPagePreviewBridge() {
				const params = new URLSearchParams(window.location.search);
				const isPreview = params.get(PAGE_EDITOR_PREVIEW_PARAM) === "1";
				if (!isPreview) {
					teardownPagePreviewBridge();
					return;
				}
				const pageId = pathnameToPageId(window.location.pathname);
				await initPagePreviewBridge(pageId);
			}

			const windowWithBridge = window as Window & {
				__pagePreviewBridgeBootstrapped?: boolean;
			};
			if (!windowWithBridge.__pagePreviewBridgeBootstrapped) {
				windowWithBridge.__pagePreviewBridgeBootstrapped = true;
				document.addEventListener("astro:page-load", () => {
					void bootPagePreviewBridge();
				});
			}
			void bootPagePreviewBridge();
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
