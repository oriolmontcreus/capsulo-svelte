---
import "../styles/global.css";
import CmsPump from "$lib/cms/CmsPump.svelte";
import ModeWatcherClient from "$lib/components/ModeWatcherClient.svelte";
import { ClientRouter } from "astro:transitions";

interface Props {
	fontFamily?: "sans" | "geist";
}

const { fontFamily = "sans" } = Astro.props as Props;
---

<!doctype html>
<html lang="en" class={fontFamily === "geist" ? "font-geist" : "font-sans"} transition:animate="none">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<ClientRouter fallback="swap" />
		<script is:inline>
			(function() {
				function applyMode() {
					try {
						const mode = localStorage.getItem("mode-watcher-mode") || "system";
						const light = mode === "light" || (mode === "system" && window.matchMedia("(prefers-color-scheme: light)").matches);
						const rootEl = document.documentElement;
						if (light) {
							rootEl.classList.remove("dark");
						} else {
							rootEl.classList.add("dark");
						}
						rootEl.style.colorScheme = light ? "light" : "dark";
					} catch (e) {}
				}
				applyMode();
				document.addEventListener("astro:after-swap", applyMode);
			})();
		</script>
	</head>
	<body>
		<slot />
		<CmsPump client:load />
		<ModeWatcherClient client:load transition:persist="mode-watcher" />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
