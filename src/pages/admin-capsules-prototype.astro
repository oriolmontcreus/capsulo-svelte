---
import Layout from "$/layouts/Layout.astro";
import CapsuleAutoDetectionPrototype from "$lib/capsules/admin/CapsuleAutoDetectionPrototype.svelte";
import capsuleManifest from "virtual:capsule-manifest";
---

<Layout>
	<main class="mx-auto max-w-5xl space-y-6 p-6">
		<div class="space-y-1">
			<h1 class="text-2xl font-semibold">Admin Capsules Prototype</h1>
			<p class="text-muted-foreground text-sm">
				Autodetected capsules and generated form instances (in-memory only).
			</p>
		</div>

		<CapsuleAutoDetectionPrototype manifest={capsuleManifest} client:load />
	</main>
</Layout>
