---
import Layout from "$/layouts/Layout.astro";
import LoginMagicLink from "$lib/LoginMagicLink.svelte";
import GlitterCloth from "$lib/motion-core/glitter-cloth/GlitterCloth.svelte";
import LightSwitch from "$lib/components/LightSwitch.svelte";
---

<Layout>
	<style>
		/*
			Chrome sometimes leaves a subpixel gap above/beside `position: fixed; inset: 0`
			elements; page background shows through. Darkened `--primary` avoids a harsh seam.
		*/
		html,
		body {
			background-color: color-mix(in oklch, var(--primary) 32%, var(--background) 100%);
		}
	</style>
	<div class="relative flex min-h-dvh w-full flex-col overflow-hidden md:flex-row">
		<div class="absolute right-4 top-4 z-20">
			<LightSwitch client:load />
		</div>
		<!-- Mobile background (GlitterCloth instead of photo) -->
		<div
			class="pointer-events-none absolute inset-0 md:hidden"
			aria-hidden="true"
			style={{ backgroundColor: "color-mix(in oklch, var(--primary) 32%, black)" }}
		>
			<GlitterCloth
				client:media="(max-width: 767px)"
				class="h-full w-full"
			/>
			<div class="absolute inset-0 bg-linear-to-b from-black/10 via-black/20 to-black/60" />
		</div>

		<!-- Desktop left panel (30% GlitterCloth) -->
		<div
			class="relative hidden min-h-dvh overflow-hidden pt-5 pl-5 md:block md:w-[30%] md:max-w-[540px] md:flex-none"
			aria-hidden="true"
			style={{ backgroundColor: "color-mix(in oklch, var(--primary) 32%, black)" }}
		>
			<div class="pointer-events-none absolute inset-0">
				<GlitterCloth
					client:media="(min-width: 768px)"
					class="h-full w-full"
				/>
			</div>
			<div class="pointer-events-none absolute inset-0 bg-linear-to-r from-black/10 via-black/20 to-black/55" />
			<h1 class="relative text-2xl font-normal text-white">Capsulo</h1>
		</div>

		<!-- Mobile content (overlayed on full-screen GlitterCloth) -->
		<div class="relative z-10 flex min-h-dvh w-full flex-col md:hidden">
			<div class="flex-1" />
			<div class="flex items-center justify-center pb-6">
				<h1 class="text-2xl font-normal text-white">Capsulo</h1>
			</div>
			<div class="mt-auto rounded-t-2xl bg-background p-6">
				<LoginMagicLink client:load />
			</div>
		</div>

		<!-- Desktop form -->
		<div class="relative z-10 hidden min-h-dvh grow items-center justify-center md:flex md:overflow-y-auto">
			<div class="w-full max-w-[320px]">
				<LoginMagicLink client:load />
			</div>
		</div>
	</div>
</Layout>