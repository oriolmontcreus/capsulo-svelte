---
import Layout from "$/layouts/Layout.astro";
import PageEditor from "$lib/PageEditor.svelte";
import capsuleManifest from "virtual:capsule-manifest";
import type { CapsuleManifestEntry } from "$lib/capsules/core/types";

type StaticPathProps = {
	pageId: string;
	entries: CapsuleManifestEntry[];
};

export function getStaticPaths() {
	return Object.entries(capsuleManifest).map(([pageId, entries]) => ({
		params: { slug: pageId },
		props: { pageId, entries }
	}));
}

const { pageId = "", entries = [] } = Astro.props as Partial<StaticPathProps>;
const hasPage = pageId.length > 0;
---

<Layout>
	{
		hasPage ? (
			<PageEditor pageId={pageId} entries={entries} client:load />
		) : (
			<main class="mx-auto max-w-3xl space-y-4 p-6">
				<h1 class="text-2xl font-semibold">Page not found</h1>
				<p class="text-muted-foreground text-sm">
					The requested page is not present in the capsule manifest.
				</p>
				<a
					href="/admin/page-editor"
					class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center rounded-md px-4 py-2 text-sm font-medium transition-colors"
				>
					Back to pages
				</a>
			</main>
		)
	}
</Layout>
