---
import Layout from "../layouts/Layout.astro";
---

<Layout fontFamily="geist">
	<main class="mx-auto flex min-h-[60dvh] max-w-3xl flex-col items-start justify-center gap-4 p-6">
		<h1 class="text-2xl font-semibold">Admin</h1>
		<p class="text-muted-foreground text-sm">
			Open the page editor to manage capsule-driven pages detected in the site.
		</p>
		<a
			href="/admin/page-editor"
			class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex items-center rounded-md px-4 py-2 text-sm font-medium transition-colors"
		>
			Open page editor
		</a>
	</main>
</Layout>
