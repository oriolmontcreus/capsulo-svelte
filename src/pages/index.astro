	<script is:inline>
		(function () {
			try {
				const banner = document.getElementById("vz-banner");
				const closeBtn = document.getElementById("vz-banner-close");
				const key = "vz-banner-closed";
				if (banner && localStorage.getItem(key) === "1") banner.style.display = "none";
				closeBtn?.addEventListener("click", (e) => {
					e.preventDefault();
					e.stopPropagation();
					localStorage.setItem(key, "1");
					if (banner) banner.style.display = "none";
				});
			} catch {}

			(function ossNav() {
				const root = document.querySelector("[data-oss]");
				if (!root) return;

				const navItems = [...root.querySelectorAll("[data-project-nav]")];
				const projects = [...root.querySelectorAll("[data-project]")];
				if (!navItems.length || !projects.length) return;

				const setActive = (idx) => {
					navItems.forEach((li) => {
						const active = Number(li.getAttribute("data-project-nav")) === idx;
						li.classList.toggle("opacity-40", !active);
						li.classList.toggle("grayscale", !active);
					});
				};

				const computeActiveFromScroll = () => {
					let bestIdx = 0;
					let bestDist = Infinity;
					const targetY = window.innerHeight * 0.35;
					for (const p of projects) {
						const idx = Number(p.getAttribute("data-project"));
						if (!Number.isFinite(idx)) continue;
						const r = p.getBoundingClientRect();
						const d = Math.abs(r.top - targetY);
						if (d < bestDist) {
							bestDist = d;
							bestIdx = idx;
						}
					}
					setActive(bestIdx);
				};

				navItems.forEach((li) => {
					const idx = Number(li.getAttribute("data-project-nav"));
					li.querySelector("button")?.addEventListener("click", () => {
						const el = projects.find((p) => Number(p.getAttribute("data-project")) === idx);
						el?.scrollIntoView({ behavior: "smooth", block: "start" });
						setActive(idx);
					});
				});

				const io = new IntersectionObserver(
					(entries) => {
						const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
						const idx = visible && Number(visible.target.getAttribute("data-project"));
						if (Number.isFinite(idx)) setActive(idx);
					},
					{ root: null, threshold: [0.25, 0.5, 0.75], rootMargin: "-25% 0px -65% 0px" },
				);
				projects.forEach((p) => io.observe(p));
				setActive(0);

				let raf = 0;
				const onScroll = () => {
					if (raf) return;
					raf = requestAnimationFrame(() => {
						raf = 0;
						computeActiveFromScroll();
					});
				};
				window.addEventListener("scroll", onScroll, { passive: true });
				window.addEventListener("resize", onScroll, { passive: true });
				computeActiveFromScroll();
			})();
		})();
	</script>
